# Confluence
# https://yourconfluece.com/display/<SPACE_KEY>/<TEAM>
CONFLUENCE_DOMAIN="https://yourconfluence.com"
CONFLUENCE_TOKEN=""
CONFLUENCE_SPACE_KEY="SPACE_KEY"
CONFLUENCE_TEAM_KEY="TEAM"

# Github
GITHUB_TOKEN=""
GITHUB_ORG_NAME="ikarius6" # your user/namespace
GITHUB_URL="https://github.com"

# Groq
GROQ_API_KEY=""

# Slack
SLACK_BOT_TOKEN=''
SLACK_APP_TOKEN=''
SLACK_SIGNING_SECRET=''

# Neo4j (run `docker compose up -d` to start)
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="changeme"

# GraphRAG options
USE_GRAPH="true"          # Set to true to enable GraphRAG retrieval
EMBED_MODEL="BAAI/bge-m3"
EMBED_BATCH_SIZE="32"
# ENTITY_MODEL="meta-llama/llama-4-scout-17b-16e-instruct" # for Groq
ENTITY_MODEL="qwen3:14b"

# Chat
# CHAT_MODEL="meta-llama/llama-4-scout-17b-16e-instruct" # for Groq
CHAT_MODEL="qwen3:14b"
OLLAMA_BASE_URL="http://host.docker.internal:11434"
#OLLAMA_BASE_URL="http://localhost:11434" # for local
USE_RERANKER="false" # require heavy lift with GPU for bge-reranker-v2-m3